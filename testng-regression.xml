<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Full regression suite - runs every @Test method tagged "regression"
  (the majority of the framework's 50+ test cases).

  Usage:
    mvn test -DsuiteXmlFile=testng-regression.xml
-->
<suite name="EcommerceRegressionSuite" verbose="1" parallel="classes" thread-count="2">

    <listeners>
        <listener class-name="com.ecommerce.automation.listeners.TestListener"/>
    </listeners>

    <test name="RegressionTests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.ecommerce.automation.tests.LoginTests"/>
            <class name="com.ecommerce.automation.tests.CartTests"/>
            <class name="com.ecommerce.automation.tests.CheckoutTests"/>
            <class name="com.ecommerce.automation.tests.PaymentTests"/>
        </classes>
    </test>

</suite>
